# =============================================================================
# Clang-Format Configuration for C++
# =============================================================================

# Базовый стиль, от которого отталкиваются все остальные настройки.
# LLVM нейтральный, хорошо читаемый стиль, подходящий для научного кода.
# Другие варианты: Google, Chromium, Mozilla, WebKit, Microsoft.
BasedOnStyle: LLVM

# Количество пробелов для одного уровня отступа.
IndentWidth: 4

# Максимальная длина строки в символах.
ColumnLimit: 100

# Сдвиг меток доступа (public:/private:/protected:) в классах.
# -4 означает: сдвинуть на 4 пробела влево относительно тела класса.
# Пример:
#   class Foo {
#     void method();  // отступ 4
#   public:           // отступ 0 (сдвинуто на -4)
#     void pub();     // отступ 4
#   };
AccessModifierOffset: -4

# Выравнивание аргументов функции после переноса строки.
# Пример:
#   auto r = func(arg1,
#                 arg2,
#                 arg3);
AlignAfterOpenBracket: Align
